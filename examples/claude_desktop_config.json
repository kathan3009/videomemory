{
  "mcpServers": {
    "videomemory_hosted": {
      "url": "https://example.com/mcp",
      "transport": "http"
    },
    "videomemory_local": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/absolute/path/to/videomemory",
        "videomemory",
        "mcp",
        "serve"
      ]
    }
  }
}
